  m_Script: {fileID: 11500000, guid: eeab04f4db333844bbc5e8fbf7c83ae0, type: 3}
  m_Name: p7_Maker
  m_EditorClassIdentifier: 
  entityName: 
  entitySprite: {fileID: 0}
  introduction:
  - "Oh, it\u2019s here, it\u2019s right here!\r"
  actionSpeakFeedback:
  - "Myself? I am a Maker, of course. Isn\u2019t it obvious? To create things is
    my calling. I can bend all materials to my will.\r"
  - 'But herein lies the problem, you see, for I have created something that must,
    I say, must be destroyed! '
  - "It\u2019s\u2026 it\u2019s too horrible to describe. A monster. A devil. A\u2026"
  - "A mistake\u2026"
  - "It grew beyond its bounds, and it forgot its master. And I fear it! Soon it
    may turn violent! Develop a thirst for destruction! For it cannot create\u2026"
  - "And it follows! It followed me even here. I know it\u2019s right behind me,
    stalking me, waiting for the slightest mistake\u2026"
  - So please! You who hold the power, clean up this sin of mine! Erase my grave
    mistake.
  - "I cannot stand to look at it\u2026 such a vile thing deserves not to be seen\u2026"
  actionPokeFeedback:
  - '[PENDING CREATURE DESIGN]'
  sparedDialogue:
  - "Please, may it not follow me further\u2026"
